# =====================================================
# MuscleUp — variables de entorno
# =====================================================
# Copia este archivo a .env.local y rellena con los valores reales.
# .env.local NO se versiona en Git (está en .gitignore).
# -----------------------------------------------------

# --- Supabase (cliente) ---
# Públicas: viajan al navegador. Toma estos valores del dashboard
# de Supabase en Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# --- Supabase (servidor) ---
# Solo para Edge Functions / scripts / cron. NUNCA exponer al cliente.
# Bypassa RLS, equivale a acceso admin total a la BD.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Supabase CLI / migraciones ---
# Necesarios solo en local para `npm run db:push`, `db:diff`, `db:types`.
# Tomar de Project Settings → General.
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
# Password del usuario "postgres" del proyecto (NO el password de tu cuenta Supabase).
# Project Settings → Database → Connection string.
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
